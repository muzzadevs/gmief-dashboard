generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Zona {
  id       Int       @id @default(autoincrement())
  nombre   String    @db.VarChar(100)
  codigo   String    @db.VarChar(10)
  subzonas Subzona[]
  iglesias Iglesia[]

  @@map("zonas")
}

model Subzona {
  id       Int       @id @default(autoincrement())
  nombre   String    @db.VarChar(100)
  zona_id  Int
  zona     Zona      @relation(fields: [zona_id], references: [id])
  iglesias Iglesia[]

  @@index([zona_id])
  @@map("subzonas")
}

model Iglesia {
  id          Int          @id @default(autoincrement())
  nombre      String       @db.VarChar(100)
  direccion   String?      @db.VarChar(255)
  municipio   String?      @db.VarChar(100)
  provincia   String?      @db.VarChar(100)
  zona_id     Int
  subzona_id  Int?
  cp          Int?
  zona        Zona         @relation(fields: [zona_id], references: [id])
  subzona     Subzona?     @relation(fields: [subzona_id], references: [id])
  ministerios Ministerio[]

  @@index([zona_id])
  @@index([subzona_id])
  @@map("iglesias")
}

model Ministerio {
  id        Int              @id @default(autoincrement())
  nombre    String           @db.VarChar(20)
  apellidos String?          @db.VarChar(60)
  alias     String?          @db.VarChar(50)
  dni_encrypted String?      @db.VarChar(255)
  iglesia_id Int
  codigo    String?          @unique(map: "codigo") @db.VarChar(7)
  estado_id Int
  tipo      String           @default("MINISTERIO") @db.VarChar(15)
  aprob     Int?
  telefono  String?          @db.VarChar(15)
  email     String?          @db.VarChar(255)
  imagen    Bytes?           @db.LongBlob
  iglesia   Iglesia          @relation(fields: [iglesia_id], references: [id])
  estado    Estado           @relation(fields: [estado_id], references: [id])
  cargos    MinisterioCargo[]
  observaciones Observacion[]
  candidato_detalle CandidatoDetalle?

  @@index([iglesia_id])
  @@index([estado_id])
  @@index([tipo])
  @@map("ministerios")
}

model Cargo {
  id          Int              @id @default(autoincrement())
  cargo       String           @db.VarChar(100)
  ministerios MinisterioCargo[]

  @@map("cargos")
}

model Estado {
  id          Int          @id @default(autoincrement())
  nombre      String       @db.VarChar(50)
  ministerios Ministerio[]

  @@map("estados")
}

model MinisterioCargo {
  id            Int        @id @default(autoincrement())
  ministerio_id Int
  cargo_id      Int
  ministerio    Ministerio @relation(fields: [ministerio_id], references: [id])
  cargo         Cargo      @relation(fields: [cargo_id], references: [id])

  @@index([ministerio_id])
  @@index([cargo_id])
  @@map("ministerio_cargo")
}

model Observacion {
  id            Int        @id @default(autoincrement())
  ministerio_id Int
  observacion   String     @db.VarChar(255)
  ministerio    Ministerio @relation(fields: [ministerio_id], references: [id])

  @@index([ministerio_id])
  @@map("observaciones")
}

model CandidatoDetalle {
  id                      Int        @id @default(autoincrement())
  ministerio_id           Int        @unique
  fecha_inicio            DateTime   @db.Date
  fecha_candidato_nacional DateTime? @db.Date
  notas                   String?    @db.VarChar(255)
  ministerio              Ministerio @relation(fields: [ministerio_id], references: [id], onDelete: Cascade)

  @@map("candidato_detalle")
}
